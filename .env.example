# Hardware Intel Bot + 가격 갱신 파이프라인 — cp .env.example .env and fill in real values.
# .env is gitignored; never commit real tokens.

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — defaults to hardware_intel.db in the project root
HARDWARE_INTEL_DB_PATH=

# 가격 갱신(/가격갱신) — 봇(VPS) 쪽에 설정. 배포된 웹앱 주소와, 아래 웹앱 섹션의
# PRICE_UPDATE_API_SECRET과 동일한 값이어야 한다.
PRICE_UPDATE_API_URL=
PRICE_UPDATE_API_SECRET=

# ── 아래는 웹앱(Vercel, /api/admin/update-prices)에 설정 — 봇 프로세스는 안 씀 ──────────────
# 네이버 쇼핑 검색 API — https://developers.naver.com 에서 발급
NAVER_SHOPPING_CLIENT_ID=
NAVER_SHOPPING_CLIENT_SECRET=
# Supabase 프로젝트 설정 > API 에서 확인(service_role 키, RLS 완전 우회 — 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
# 위 봇 섹션의 PRICE_UPDATE_API_SECRET과 동일한 값
PRICE_UPDATE_API_SECRET=
